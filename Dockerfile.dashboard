FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    streamlit>=1.30.0 \
    plotly>=5.18.0 \
    pandas>=2.0.0 \
    sqlalchemy>=2.0.0 \
    psycopg2-binary>=2.9.0

COPY dashboards/app.py ./app.py

EXPOSE 8501

CMD ["streamlit", "run", "app.py", "--server.address", "0.0.0.0", "--server.port", "8501", "--browser.gatherUsageStats", "false"]
