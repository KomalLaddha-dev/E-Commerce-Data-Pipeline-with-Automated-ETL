# ──────────────────────────────────────────────
# Environment Variables Configuration
# E-commerce Data Pipeline with Automated ETL
# ──────────────────────────────────────────────

# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control

# ── Docker Compose & Setup ──────────────────
PG_HOST=postgres
PG_PORT=5432
PG_USER=etl_user
PG_PASSWORD=your_secure_password_here
PG_DB=postgres

# ── Source Database (OLTP) ──────────────────
SOURCE_DB_HOST=postgres
SOURCE_DB_PORT=5432
SOURCE_DB_USER=etl_user
SOURCE_DB_PASSWORD=your_source_db_password
SOURCE_DB_NAME=ecommerce_db
SOURCE_DB_DRIVER=postgresql

# ── Data Warehouse (OLAP) ───────────────────
DW_HOST=postgres
DW_PORT=5432
DW_USER=etl_user
DW_PASSWORD=your_warehouse_password
DW_NAME=ecommerce_dw
DW_DRIVER=postgresql

# ── Large Synthetic Data Generation ─────────
ENABLE_LARGE_DATA=true
LARGE_DATA_CUSTOMERS=20000
LARGE_DATA_PRODUCTS=3000
LARGE_DATA_ORDERS=120000
LARGE_DATA_ORDER_LOOKBACK_HOURS=8760
LARGE_DATA_MIN_ORDER_SPAN_DAYS=90
LARGE_DATA_PREMIUM_CUSTOMER_PERCENT=15
LARGE_DATA_REGULAR_CUSTOMER_PERCENT=45
LARGE_DATA_PREMIUM_ORDER_SHARE=0.72
LARGE_DATA_MAX_AVG_ORDER_VALUE=60

# ── Airflow Configuration (Optional) ────────
AIRFLOW__CORE__DAGS_FOLDER=./airflow_dags
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__MAX_ACTIVE_RUNS=1

# ── Notification ────────────────────────────
ALERT_EMAIL=data-alerts@company.com
