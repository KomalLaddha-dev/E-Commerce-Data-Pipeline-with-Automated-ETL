# ──────────────────────────────────────────────
# Environment Variables Configuration
# E-commerce Data Pipeline with Automated ETL
# ──────────────────────────────────────────────

# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control

# ── Docker Compose & Setup ──────────────────
PG_HOST=postgres
PG_PORT=5432
PG_USER=etl_user
PG_PASSWORD=your_secure_password_here
PG_DB=postgres

# ── Source Database (OLTP) ──────────────────
SOURCE_DB_HOST=localhost
SOURCE_DB_PORT=3306
SOURCE_DB_USER=etl_service
SOURCE_DB_PASSWORD=your_source_db_password
SOURCE_DB_NAME=ecommerce_db
SOURCE_DB_DRIVER=mysql+pymysql

# ── Data Warehouse (OLAP) ───────────────────
DW_HOST=localhost
DW_PORT=5432
DW_USER=warehouse_user
DW_PASSWORD=your_warehouse_password
DW_NAME=ecommerce_dw
DW_DRIVER=postgresql

# ── Airflow Configuration (Optional) ────────
AIRFLOW__CORE__DAGS_FOLDER=./airflow_dags
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__MAX_ACTIVE_RUNS=1

# ── Notification ────────────────────────────
ALERT_EMAIL=data-alerts@company.com
